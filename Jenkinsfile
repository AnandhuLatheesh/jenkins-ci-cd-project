pipeline
 {
    agent any

    stages {

        stage('Clone Check') {
            steps {
                sh 'echo Repository cloned successfully'
            }
        }

        stage('Build Stage') {
            steps {
                sh 'echo Building application...'
            }
        }

        stage('Deploy Stage') {
            steps {
                sh 'echo Deploying application...'
            }
        }
            }
}